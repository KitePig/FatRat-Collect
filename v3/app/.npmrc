# pnpm 跨平台/跨版本兼容配置
# 支持：Intel Mac / Apple Silicon Mac / Windows / Linux 服务器

# 自动安装 peer 依赖
auto-install-peers=true
# 不严格校验 peer 依赖版本
strict-peer-dependencies=false
# 允许 pnpm 版本与 packageManager 声明不完全匹配时仍可运行
# 避免因 lockfile 版本差异导致可选原生依赖（如 @rollup/rollup-darwin-x64）未安装
package-manager-strict-version=false
